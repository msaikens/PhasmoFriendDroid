<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/behavior_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/phasmo_background"
    android:padding="16dp"
    tools:context=".ui.notifications.BehaviorFragment">

    <!-- Title -->
    <TextView
        android:id="@+id/behavior_screen_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/behavior_screen_title"
        android:textAppearance="@style/TextAppearance.MaterialComponents.Headline6"
        android:textColor="@color/phasmo_text_primary"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:text="Behavior &amp; Hunt Clues" />

    <!-- Subtitle / helper text -->
    <TextView
        android:id="@+id/behavior_screen_subtitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="@string/behavior_screen_subtitle"
        android:textAppearance="@style/TextAppearance.MaterialComponents.Body2"
        android:textColor="@color/phasmo_text_secondary"
        app:layout_constraintStart_toStartOf="@id/behavior_screen_title"
        app:layout_constraintEnd_toEndOf="@id/behavior_screen_title"
        app:layout_constraintTop_toBottomOf="@id/behavior_screen_title"
        tools:text="@string/behavior_subtitle_hint" />

    <!-- Search field -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/behavior_search_container"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        app:boxBackgroundMode="outline"
        app:boxStrokeColor="@color/phasmo_accent"
        app:endIconMode="clear_text"
        app:layout_constraintStart_toStartOf="@id/behavior_screen_title"
        app:layout_constraintEnd_toEndOf="@id/behavior_screen_title"
        app:layout_constraintTop_toBottomOf="@id/behavior_screen_subtitle">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/behavior_search"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/behavior_search_hint"
            android:imeOptions="actionDone"
            android:inputType="text"
            android:maxLines="1" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Scrollable list of behavior checkboxes -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/behavior_card"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        app:cardBackgroundColor="@color/phasmo_surface"
        app:cardCornerRadius="12dp"
        app:cardUseCompatPadding="true"
        app:cardElevation="2dp"
        app:layout_constraintTop_toBottomOf="@id/behavior_search_container"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="@id/behavior_screen_title"
        app:layout_constraintEnd_toEndOf="@id/behavior_screen_title">

        <ScrollView
            android:id="@+id/behavior_scroll_container"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <LinearLayout
                android:id="@+id/behavior_checkbox_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp" />
        </ScrollView>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>
